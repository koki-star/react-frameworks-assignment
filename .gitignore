# ============================================
# Root .gitignore — React Frameworks Monorepo
# (Next.js, Remix, Gatsby, Expo)
# ============================================

# ----- Dependencies -----
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ----- Next.js -----
.next/
out/

# ----- Remix / React Router -----
.react-router/

# ----- Gatsby -----
.cache/
public/

# ----- Expo / React Native -----
.expo/
dist/
web-build/
expo-env.d.ts
ios/
android/
.kotlin/
.metro-health-check*

# ----- General build output -----
build/

# ----- Testing -----
coverage/

# ----- Environment files -----
.env
.env.*

# ----- Log files -----
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ----- TypeScript -----
*.tsbuildinfo
next-env.d.ts
src/gatsby-types.d.ts

# ----- OS-generated files -----
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
._*
.Spotlight-V100
.Trashes

# ----- IDE / Editor files -----
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# ----- Certificates & secrets -----
*.pem
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.orig.*

# ----- Deployment -----
.vercel
.netlify

# ----- Misc -----
*.log
*.pid
*.seed
*.pid.lock
